.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  height: 76rpx;
  background: #fff;
  border-radius: 38rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.search-btn {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 38rpx;
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 0 30rpx;
}

.search-btn::after {
  border: none;
}

.loading,
.empty {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 40rpx 0;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.cover {
  width: 210rpx;
  height: 130rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  line-height: 42rpx;
}

.desc {
  margin-top: 8rpx;
  color: #999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.bottom {
  margin-top: 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.teacher {
  color: #666;
  font-size: 24rpx;
}

.price {
  color: #ff4d4f;
  font-size: 30rpx;
  font-weight: 700;
}
